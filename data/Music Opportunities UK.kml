          </Data>
          <Data name="6. Ensemble (if app.)">
            <value>Orchestra</value>
          </Data>
          <Data name="7. Genre">
            <value>Jazz</value>
          </Data>
          <Data name="8. Age">
            <value>Up to 21</value>
          </Data>
          <Data name="9. Level">
            <value><![CDATA[Ideally Grade 6+, 3 x trial rehearsals & audition required]]></value>
          </Data>
          <Data name="10. Instruments">
            <value/>
          </Data>
          <Data name="11. Other Tags">
            <value>Audition, Grade 6, Grade 7, Grade 8</value>
          </Data>
