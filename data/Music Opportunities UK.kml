          <Data name="6. Ensemble (if app.)">
            <value>Musical Theatre Group</value>
          </Data>
          <Data name="7. Genre">
            <value>Musical Theatre</value>
          </Data>
          <Data name="8. Age">
            <value>12 - 18</value>
          </Data>
          <Data name="9. Level">
            <value>audtioned</value>
